{
  "name": "hermes-ai-flow-poc",
  "version": "1.0.0",
  "description": "Reusable Hermes PM framework for GitHub Issues based autonomous execution.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "poll:tasks": "node scripts/task-poller.mjs",
    "worker:once": "node scripts/task-worker.mjs --once",
    "worker:watch": "node scripts/task-worker.mjs --watch",
    "framework:doctor": "node scripts/framework-doctor.mjs",
    "test": "vitest run",
    "lint": "eslint src tests scripts"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "eslint": "^9.34.0",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
